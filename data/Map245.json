{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"sliding_door_O","volume":90,"pitch":100,"pan":0}]},{"code":235,"indent":0,"parameters":[30]},{"code":211,"indent":0,"parameters":[1]},{"code":213,"indent":0,"parameters":[-1,7,true]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Disgust welled up from every cell in my body and I felt like throwing up."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["The onee-san that I've always looked up to."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I kept it a secret from everyone... and it was only for a short time, but--"]},{"code":401,"indent":0,"parameters":["Rino nee-san was my first love."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I wonder how long it's been going for?"]},{"code":401,"indent":0,"parameters":["...And with my old man, of all people. Why? Is it because he's a bigshot?"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Did he help her with a mess she made at work or something?"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...If I had just a bit more power,"]},{"code":401,"indent":0,"parameters":["it could have been me there instead."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["--No, still. I... I have Shino."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I still can't get my head in order so... let's go see her tomorrow."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I threw the necktie I bought for my old man into the bin,"]},{"code":401,"indent":0,"parameters":["crawled into bed and forced my eyes close."]},{"code":231,"indent":0,"parameters":[40,"blace",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[40,0,0,0,0,0,100,100,255,0,30,true,0]},{"code":235,"indent":0,"parameters":[100]},{"code":232,"indent":0,"parameters":[62,0,0,0,456,500,100,100,255,0,25,false,2]},{"code":235,"indent":0,"parameters":[62]},{"code":250,"indent":0,"parameters":[{"name":"Magic1","volume":70,"pitch":70,"pan":0}]},{"code":231,"indent":0,"parameters":[70,"time/05深夜",0,0,328,56,60,60,255,0]},{"code":235,"indent":0,"parameters":[45]},{"code":230,"indent":0,"parameters":[20]},{"code":250,"indent":0,"parameters":[{"name":"BirdK","volume":70,"pitch":80,"pan":0}]},{"code":231,"indent":0,"parameters":[71,"time/01朝",0,0,328,56,60,60,0,0]},{"code":232,"indent":0,"parameters":[71,0,0,0,328,56,60,60,255,0,60,true,2]},{"code":235,"indent":0,"parameters":[70]},{"code":232,"indent":0,"parameters":[71,0,0,0,328,-592,60,60,255,0,30,false,2]},{"code":230,"indent":0,"parameters":[30]},{"code":235,"indent":0,"parameters":[71]},{"code":221,"indent":0,"parameters":[]},{"code":242,"indent":0,"parameters":[2]},{"code":230,"indent":0,"parameters":[120]},{"code":201,"indent":0,"parameters":[0,252,14,3,6,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":14,"y":1},
