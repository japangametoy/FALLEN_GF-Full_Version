ameters":[71,0,0,0,328,56,60,60,255,0,60,true,2]},{"code":235,"indent":0,"parameters":[70]},{"code":232,"indent":0,"parameters":[71,0,0,0,328,-592,60,60,255,0,30,false,2]},{"code":230,"indent":0,"parameters":[30]},{"code":235,"indent":0,"parameters":[71]},{"code":232,"indent":0,"parameters":[25,0,0,0,0,0,100,100,0,0,60,true,0]},{"code":235,"indent":0,"parameters":[25]},{"code":117,"indent":0,"parameters":[90]},{"code":235,"indent":0,"parameters":[1]},{"code":241,"indent":0,"parameters":[{"name":"3_EventScene_1","volume":90,"pitch":100,"pan":0}]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["--As I was passing by the office that both Rino nee-san and my"]},{"code":401,"indent":0,"parameters":["father worked at, I remembered the event from the other day."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["That day when Rino nee-san asked me for advice. ...It had been a few days since."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Since then, she's been a bit busy so I haven't gotten the chance to see her,"]},{"code":401,"indent":0,"parameters":["but I do wonder if whatever she was worried about went well."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["She's at work but just going and saying hi shouldn't hurt. But as I made my way in..."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I was told that she was in a meeting."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":250,"indent":0,"parameters":[{"name":"step2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It's probably not the best thing to be doing, but as I was wandering around"]},{"code":401,"indent":0,"parameters":["an empty area of the office, I came across a room that had"]},{"code":401,"indent":0,"parameters":["\"conference room\" written on the signboard."]},{"code":231,"indent":0,"parameters":[20,"rinoofisuback",0,0,-288,-88,100,100,0,0]},{"code":232,"indent":0,"parameters":[20,0,0,0,-288,-88,100,100,255,0,30,true,0]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["She's probably doing her best in there."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Guess I'll kill some time outside then come back."]},{"code":401,"indent":0,"parameters":["She did tell me once before that I shouldn't go in there."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["One day, if I end up working here too, I'll probably be able to see what lies past"]},{"code":401,"indent":0,"parameters":["this door. While thinking such things, I went over to the karaoke place next door."]},{"code":235,"indent":0,"parameters":[100]},{"code":250,"indent":0,"parameters":[{"name":"step1","volume":100,"pitch":90,"pan":0}]},{"code":230,"indent":0,"parameters":[180]},{"code":231,"indent":0,"parameters":[21,"rinoofisuback2",0,0,-288,-88,100,100,0,0]},{"code":232,"indent":0,"parameters":[21,0,0,0,-288,-88,100,100,255,0,30,true,0]},{"code":235,"indent":0,"parameters":[20]},{"code":230,"indent":0,"parameters":[100]},{"code":242,"indent":0,"parameters":[2]},{"code":231,"indent":0,"parameters":[22,"rinoofisuback3",0,0,-288,-88,100,100,0,0]},{"code":232,"indent":0,"parameters":[22,0,0,0,-288,-88,100,100,255,0,30,true,0]},{"code":235,"indent":0,"parameters":[21]},{"code":230,"indent":0,"parameters":[240]},{"code":231,"indent":0,"parameters":[23,"rinoofisuback4",0,0,-288,-88,100,100,0,0]},{"code":245,"indent":