{"name":"Rino","wait":"def","speed":"def","direction":"auto","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Rino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["スライドスピード = def"]},{"code":657,"indent":0,"parameters":["スライド方向。 = auto"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":250,"indent":0,"parameters":[{"name":"writing_in_a_pen","volume":90,"pitch":100,"pan":0}]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["As I was taking down even more detailed notes..."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Father"]},{"code":401,"indent":0,"parameters":["-- You're so full of energy."]},{"code":251,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I heard my dad... I mean, the director's voice from behind."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["[Yes, I'll do my best to become just like you, chief.]"]},{"code":401,"indent":0,"parameters":["I bowed towards him."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Father"]},{"code":401,"indent":0,"parameters":["Good, good... Keep working hard."]},{"code":401,"indent":0,"parameters":["...I have high expectations, \\n[1]."]},{"code":235,"indent":0,"parameters":[100]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","moveOut","[退出]moveOut/ムーブアウト",{"name":"Father","wait":"def","speed":"def","direction":"auto","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Father"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["スライドスピード = def"]},{"code":657,"indent":0,"parameters":["スライド方向。 = auto"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["As I watched the father I respected walk away, I sat down on my desk with renewed resolve."]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"edbg2",0,0,-360,-192,100,100,255,0]},{"code":357,"indent":0,"parameters":["NRP_PicturePriority","SetZ","Ｚ座標を設定",{"PictureId":"1","Z":"0.90"}]},{"code":657,"indent":0,"parameters":["ピクチャ番号 = 1"]},{"code":657,"indent":0,"parameters":["Ｚ座標 = 0.90"]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Ayano"]},{"code":401,"indent":0,"parameters":["\\SE[4-nb]...so, that's how it worked out, is that alright?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["In the conference room, I looked over the materials presented by Ayano-san."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Ayano"]},{"code":401,"indent":0,"parameters":["\\se[5-nb]Fufuh--, I never thought the day would come when we"]},{"code":401,"indent":0,"parameters":["would work together like this~♥"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Ayano"]},{"code":401,"indent":0,"parameters":["\\se[15-nb]I think I might just cry..."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I was having a work meeting with Ayano-san in the office."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["She's also involved in our company's work, so there's"]},{"code":401,"indent":0,"parameters":["quite a few opportunities for us to work together like this."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Ayano"]},{"code":401,"indent":0,"parameters