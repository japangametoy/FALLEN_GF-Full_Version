indent":0,"parameters":[20]},{"code":231,"indent":0,"parameters":[1,"bg1",0,0,-368,-680,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["It's the candy store we used to go to a lot, as kids. We used to take our"]},{"code":401,"indent":0,"parameters":["tiny allowances and pool them together, and share all kinds of stuff."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["...We could never agree on whose favourites to buy, of course."]},{"code":401,"indent":0,"parameters":["Fufuh--, I was the stronger one of us back then though, so"]},{"code":401,"indent":0,"parameters":["you always had to give in."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I smiled wrily as I thought back to just how tyrannical she used to be."]},{"code":401,"indent":0,"parameters":["Ah, she's grown up and softened out so much... in more ways than one."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["Next is over there~"]},{"code":221,"indent":0,"parameters":[]},{"code":230,"indent":0,"parameters":[20]},{"code":231,"indent":0,"parameters":[1,"bg3",0,0,-432,-408,90,90,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["It's the shrine I sneaked into by myself to explore, do you remember?"]},{"code":401,"indent":0,"parameters":["I was such a brat back then... It's embarrassing to think about..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["You searched for me everywhere too, \\n[1]. Mom told me"]},{"code":401,"indent":0,"parameters":["all about it afterwards. Fufuh--... thanks."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["...But after onee-chan found me, everyone started making a"]},{"code":401,"indent":0,"parameters":["fuss because you hadn't come back. It's kind of funny,"]},{"code":401,"indent":0,"parameters":["thinking back to it now~"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Even now, I remember the embarrassment of the moment like it was yesterday."]},{"code":401,"indent":0,"parameters":["It was a typical case of going out for wool and coming home shorn."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[13-nb]Eheheh, I'm sorry. ...But it made me really happy, you know?"]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[1]},{"code":230,"indent":0,"parameters":[20]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[13-nb]It wasn't all happy times, of course."]},{"code":401,"indent":0,"parameters":["But someday, when we're adults..."]},{"code":401,"indent":0,"parameters":["I'm sure they'll all be wonderful memories to look back at."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[11]...I want to, make lots and lots more memories together."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Her happy, yet melancholic expression captivated my eyes, and took my breath away."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...Our gazes overlapped, though she looked away first."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SM[double]\\se[14-nb]Eheheh, I'm starting to feel a bit sentimental. "]},{"code":401,"indent":0,"parameters":["Let's see, I think it's about time for me to head home~."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SM[rock]\\SE[11]See you later then--!"]},{"code":401,"indent":0,"parameters":["...Thanks for keeping me company."]},{"code":235,"indent":0,"parameters":[100]},{"code":205,"indent":0,"parameters":[0,{"list":[{"code":39,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":39,"indent":null}]},{"code":230,"indent":0,"parameters":[30]},{"code":250,"indent":0,"parameters":[{"name":"Close1","volume":70,"pitch":100,"pan":0}]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","moveOut","[退出]moveOut/ムーブアウト",{"name":"Shino","wait":"def","speed":"def","direction":"auto","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Shino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["スライドスピード = def"]},{"code":657,"indent":0,"parameters":["スライド方向。 = auto"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I watched her back as she went inside."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...The day will certainly come, when this scenery will no longer be something we can take \nfor granted."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Thinking along those lines, I considered burning it into my eyes while I could."]},{"code":401,"indent":0,"parameters":["And so I leaned against the railing, and gazed at the dusk."]},{"code":117,"indent":0,"parameters":[97]},{"code":122,"indent":0,"parameters":[91,9