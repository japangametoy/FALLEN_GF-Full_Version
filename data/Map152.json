{"id":7,"name":"","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":261,"switch2Valid":false,"variableId":91,"variableValid":false,"variableValue":2},"directionFix":true,"image":{"tileId":0,"characterName":"shino","direction":6,"pattern":0,"characterIndex":0},"list":[{"code":123,"indent":0,"parameters":["A",0]},{"code":357,"indent":0,"parameters":["Keke_LoopBalloon","フキダシアイコンの消去","フキダシアイコンの消去",{"対象キャラ-名前":"7","対象キャラ-ID":""}]},{"code":657,"indent":0,"parameters":["対象キャラ-名前 = 7"]},{"code":657,"indent":0,"parameters":["対象キャラ-ID = "]},{"code":201,"indent":0,"parameters":[0,112,8,12,8,2]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["As I was walking aimlessly around town, with the thought"]},{"code":401,"indent":0,"parameters":["that walks are nice every so often too... I met someone unexpected."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[124]\\SM[pop]\\SE[8]Huh, \\n[1]. What's up? Why're you here?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I returned that same question to her."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[10]Me? I'm actually going to be working as a part time tutor from today~"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["That was the first I was hearing of it."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[30-nb]\\SA[130]It was a pretty sudden arrangement so I might've forgotten to tell you, sorry."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[32-nb]This is Keiichi-kun. He's... the son of a very~"]},{"code":401,"indent":0,"parameters":["important national diet member, you see."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I did hear rumours before about this being the house of some big shot."]},{"code":401,"indent":0,"parameters":["Just when did Shino get herself connections like this?"]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[0]I'm Keiichi. Nice to meet you!"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\sa[123]\\SE[3]Are you Shino-sensei's boyfriend, onii-san?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Damn, what a sudden question."]},{"code":401,"indent":0,"parameters":["Erhm, uhm... yes but no, it's hard to explain..."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["[T-That's right]"]},{"code":401,"indent":0,"parameters":["is what I answered with, while ending up a bit flustered."]},{"code":401,"indent":0,"parameters":["...It's not like it's wrong, so there's no reason for me to panic."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[42]\\SA[128]Y-Yes, it's like that..."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["She hung her head with a similarly red face."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[1]I see~, I can understand. Shino-sensei's just so cute."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\se[2]Sorry, \\n[1] onii-san, I'll be borrowing her for a bit."]},{"code":401,"indent":0,"parameters":["I just have to have her tutor me, so that I can become a man"]},{"code":401,"indent":0,"parameters":["like my own father someday."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[30]\\SA[130]I just happened to meet him in town one day, you know?"]},{"code":401,"indent":0,"parameters":["That's when he asked me to be his tutor. It caught me so off-guard."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[32-nb]It's not like I have insanely good grades either but,"]},{"code":401,"indent":0,"parameters":["I ended up giving in to Keiichi-kun's enthusiasm."]},{"code":401,"indent":0,"parameters":["...I'll try to do what I can, so be patient with me."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[2]At first I only shot my shot since it couldn't hurt but,"]},{"code":401,"indent":0,"parameters":["listening to how she just wanted to be more helpful to her"]},{"code":401,"indent":0,"parameters":["family really made me fall for her..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\sa[124]\\SM[pop]\\SE[19]I'll do my best so, please take care of me!"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[21]Well then, it's about time we started, see you later, \\n[1]."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[1]Goodbye, \\n[1] onii-san."]},{"code":235,"indent":0,"parameters":[100]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","moveOut","[退出]moveOut/ムーブアウト",{"name":"all","wait":"def","speed":"def","direction":"auto","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = all"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["スライドスピード = def"]},{"code":657,"indent":0,"parameters":["スライド方向。 = auto"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I saw off Shino and the politely bowing Keiichi-kun."]},{"code":401,"indent":0,"parameters":["...He's got a good head on his shoulders."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Let's see, I guess I should do something too. Seeing those"]},{"code":401,"indent":0,"parameters":["two hardworkers made me feel a bit impatient myself, and so I left."]},{"code":117,"indent":0,"parameters":[97]},{"code":121,"indent":0,"parameters":[273,273,0]},{"code":122,"indent":0,"parameters":[183,183,0,0,1]},{"code":122,"indent":0,"parameters":[91,91,1,0,1]},{"code":117,"indent":0,"parameters":[74]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":39,"indent":null},{"code":40,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":39,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":40,"indent":null}]},{"code":235,"indent":0,"parameters":[13]},{"code":123,"indent":0,"parameters":["A",1]},{"code":121,"indent":0,"parameters":[62,62,1]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":false}],"x":8,"y":3},
