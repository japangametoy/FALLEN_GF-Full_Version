s":[1,{"list":[{"code":25,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":25,"indent":null}]},{"code":213,"indent":0,"parameters":[-1,1,false]},{"code":213,"indent":0,"parameters":[10,1,false]},{"code":213,"indent":0,"parameters":[1,1,true]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[8]\\SM[jump]Wah--... \\n[1]."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[0]...\\n[1] onii-san, hi there. It's been a while."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It was only because of these two that I was able to grasp my new future."]},{"code":401,"indent":0,"parameters":["There were no better people I could tell this good news to."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I told them both about what just happened."]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[-1,8,true]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[21]Ufufuh--, that's amazing, \\n[1]. You have been working pretty darn hard lately~...."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\se[18-nb]Ahahah--. Congratulations!"]},{"code":401,"indent":0,"parameters":["I'm happy for you."]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[-1,8,true]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I thanked him in turn, telling him [It's because you introduced me to him]."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"co