,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[21]\\n[1]... are you just coming back home? You've been working very hard lately, huh?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Was he here to drop her off? Maybe that's why they were chatting..."]},{"code":401,"indent":0,"parameters":["Just as that thought passed through my head--"]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[1,3,true]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["\\SE[0]I was actually waiting for you today, \\n[1] onii-san."]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[-1,2,true]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Me...? I wonder why. There can't be anything he needs from me of all people."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["I heard from Shino-sensei, that you've been working really hard at your studies."]},{"code":213,"indent":0,"parameters":[10,8,false]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["So erhm, if you'd like, that is... I know someone at the university that"]},{"code":401,"indent":0,"parameters":["you're attempting to get into, you see..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Kid"]},{"code":401,"indent":0,"parameters":["How about I arrange a meeting? I think it'd work out great, personally."]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[-1,1,true]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I couldn't even ask for more. [I'd love that, please and than