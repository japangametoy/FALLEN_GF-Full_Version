he only way I could think of at the time."]},{"code":235,"indent":0,"parameters":[100]},{"code":213,"indent":0,"parameters":[2,8,true]},{"code":231,"indent":0,"parameters":[2,"blace",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[5]},{"code":231,"indent":0,"parameters":[1,"beranda2",0,0,-632,-216,100,100,255,0]},{"code":357,"indent":0,"parameters":["NRP_PicturePriority","SetZ","Ｚ座標を設定",{"PictureId":"1","Z":"0.90"}]},{"code":657,"indent":0,"parameters":["ピクチャ番号 = 1"]},{"code":657,"indent":0,"parameters":["Ｚ座標 = 0.90"]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","pose","[表情/ポーズ]pose/ポーズ変更",{"name":"Shino","wait":"def","pose":"hiki","expression":"","style":"def","duration":"def","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Shino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["ポーズ名 = hiki"]},{"code":657,"indent":0,"parameters":["表情名 = "]},{"code":657,"indent":0,"parameters":["アニメーションタイプ = def"]},{"code":657,"indent":0,"parameters":["所要時間 = def"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I hardened my resolve, and climbed the railing..."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["-- And leaped right onto Shino's side of the balcony."]},{"code":201,"indent":0,"parameters":[0,126,6,6,0,0]},{"code":211,"indent":0,"parameters":[0]},{"code":357,"indent":0,"parameters":["NRP_PicturePriority","SetZ","Ｚ座標を設定",{"PictureId":"1","Z":"0.90"}]},{"code":657,"indent":0,"parameters":["ピクチャ番号 = 1"]},{"code":657,"indent":0,"parameters":["Ｚ座標 = 0.90"]},{"code":242,"indent":0,"parameters":[2]},{"code":235,"indent":0,"parameters":[100]},{"code":232,"indent":0,"parameters":[2,0,0,0,0,0,100,100,0,0,30,false,0]},{"code":250,"indent":0,"parameters":[{"name":"Damage2","volume":90,"pitch":100,"pan":0}]},{"code":225,"indent":0