lie"]},{"code":401,"indent":0,"parameters":["Hahah--, I actually realized somethin' the other day, ya see."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Charlie"]},{"code":401,"indent":0,"parameters":["The channel's been stuck in a rut for a while, and today made it super clear."]},{"code":242,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,2,2,"Charlie"]},{"code":401,"indent":0,"parameters":["---Shino-chan, you've been feelin' pretty... unsatisfied lately, no?"]},{"code":241,"indent":0,"parameters":[{"name":"5_EventScene_3","volume":90,"pitch":100,"pan":0}]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Feeling like something I'd been hiding deep inside my heart"]},{"code":401,"indent":0,"parameters":["was caught, I got startled like a deer in headlights."]},{"code":231,"indent":0,"parameters":[30,"blace",0,0,0,0,100,100,0,0]},{"code":250,"indent":0,"parameters":[{"name":"kinunugi1","volume":90,"pitch":100,"pan":0}]},{"code":232,"indent":0,"parameters":[30,0,0,0,0,0,100,100,255,0,30,true,0]},{"code":235,"indent":0,"parameters":[20]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Charlie"]},{"code":401,"indent":0,"parameters":["So, next time..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["Eh... are you serious...? But...."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Charlie"]},{"code":401,"indent":0,"parameters":["Is it too much? I mean I ain't gonna ask ya to do the impossible."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["You'll keep it all a secret, right?"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Charlie"]},{"code":401,"indent":0,"parameters":["Of course. I said it before too, but I'm the one who's gonna be in trouble if this gets out."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["Alright then... sure."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Already, my head was already full of just one thought."]},{"code":401,"indent":0,"parameters":["...Just what sort of unknown will I get to experience this time?"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...I mean, either way it won't change anything."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["So we might as well... go all the way."]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","end","スキット終了",{"noAnimation":"false"}]},{"code":657,"indent":0,"parameters":["瞬時に非表示 = false"]},{"code":235,"indent":0,"parameters":[100]},{"code":242,"indent":0,"parameters":[2]},{"code":111,"indent":0,"parameters":[0,530,0]},{"code":221,"indent":1,"parameters":[]},{"code":201,"indent":1,"parameters":[1,26,27,28,0,0]},{"code":223,"indent":1,"parameters":[[0,0,0,0],1,false]},{"code":211,"indent":1,"parameters":[1]},{"code":121,"indent":1,"parameters":[530,530,1]},{"code":235,"indent":1,"parameters":[1]},{"code":235,"indent":1,"parameters":[30]},{"code":135,"indent":1,"parameters":[1]},{"code":121,"indent":1,"parameters":[389,389,1]},{"code":119,"indent":1,"parameters":["aiso"]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":221,"indent":0,"parameters":[]},{"code":223,"indent":0,"parameters":[[0,0,0,0],1,false]},{"code":235,"indent":0,"parameters":[60]},{"code":201,"indent":0,"parameters":[0,355,18,4,2,0]},{"code":235,"indent":0,"parameters":[30]},{"code":118,"indent":0,"parameters":["aiso"]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3