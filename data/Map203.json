indent":0,"parameters":["Rino - Another Route [The day I quit being their ideal onee-chan.]"]},{"code":230,"indent":0,"parameters":[120]},{"code":241,"indent":0,"parameters":[{"name":"M08_Kanashimi_Key","volume":90,"pitch":100,"pan":0}]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","autoFocus","[演出]autoFocus/オートフォーカス",{"autoFocusFlag":"false"}]},{"code":657,"indent":0,"parameters":["オートフォーカスを有効 = false"]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","expression","[表情/ポーズ]exp/表情変更",{"name":"Rino","wait":"def","expression":"5","duration":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Rino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["表情名 = 5"]},{"code":657,"indent":0,"parameters":["所要時間 = def"]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","show","[登場]show/キャラ表示",{"name":"Rino","wait":"","position":"中央","opacity":"255"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Rino"]},{"code":657,"indent":0,"parameters":["__ダミー(ウェイト) = "]},{"code":657,"indent":0,"parameters":["位置 = 中央"]},{"code":657,"indent":0,"parameters":["不透明度 = 255"]},{"code":121,"indent":0,"parameters":[40,40,0]},{"code":232,"indent":0,"parameters":[1,0,0,0,0,0,100,100,0,0,20,true,0]},{"code":235,"indent":0,"parameters":[1]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["\\SE[5]...I messed up at work. In a big way at that."]},{"code":401,"indent":0,"parameters":["It didn't turn into anything, only because the chief covered for me."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I was in completely over my head. I lost control of the situation"]},{"code":401,"indent":0,"parameters":["in a truly pathetic manner."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["If \\n[2]'s dad... if the chief didn't come to my rescue,"]},{"code":401,"indent":0,"parameters":["that one mistake would have caused some damage to the company."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Rino"]},{"code":401,"indent":0,"parameters":["\\SE[11-nb]But I didn't get fired. And everyone makes mistakes."]},{"code":401,"indent":0,"parameters":["I couldn't have helped it. It happens, it is what it is."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["But even though I made excuses like that to myself, I couldn't accept them."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I endured and put up with a lot to get here but, in the end..."]},{"code":401,"indent":0,"parameters":["I'm always going to be like this."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Maybe if I had spent my time messing around with men instead,"]},{"code":401,"indent":0,"parameters":["I would have turned out a smarter, cleverer woman."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It's not like I don't find it crazy myself, making up for a mistake with my body and all."]},{"code":401,"indent":0,"parameters":["...Especially a girl like me, with 0 experience."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["But, though it was only out of a sense of duty at first... "]},{"code":401,"indent":0,"parameters":["I definitely felt it changing into something I'd never felt until now."]},{"code":231,"indent":0,"parameters":[1,"h_ri/r-1-1",0,0,0,0,100,100,0,0]},{"code":234,"indent":0,"parameters":[1,[34,-34,-68,170],1,false]},{"code":232,"indent":0,"parameters":[1,0,0,0,0,0,100,100,255,0,30,true,0]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["When I do lewd stuff, my head goes entirely blank..."]},{"code":401,"indent":0,"parameters":["and I stop thinking about all the unnecessary stuff completely."]},{"code":232,"indent":0,"parameters":[1,0,0,0,0,0,100,100,0,0,30,true,0]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["--But in return, I'm hit with an insane sense of guilt after the fact."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["My little sister, and her boyfriend. Those two look up to me so much,"]},{"code":401,"indent":0,"parameters":["and each time it feels like I've betrayed them for my own selfish reasons."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["With those sorts of thoughts running through my head, I walked down the road home, \nin a daze."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It was then that I saw my little sister's boyfriend heading into the local bar."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I warned him maturely, that he was still too young for a place like that,"]},{"code":401,"indent":0,"parameters":["and sent him on his way home."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...But I'm an adult. What does it matter? I'm here anyway."]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","end","スキット終了",{"noAnimation":"false"}]},{"code":657,"indent":0,"parameters":["瞬時に非表示 = false"]},{"code":235,"indent":0,"parameters":[100]},{"code":201,"indent":0,"parameters":[0,231,6,8,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":7,"y":6}]}