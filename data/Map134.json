01,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[8]...."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Me and her, in the booth. Just us. The time around us, passing in silence."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["The wave of embarrassment from my actions earlier finally"]},{"code":401,"indent":0,"parameters":["hitting me, I nearly pass out."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Even if I did just see that dream,"]},{"code":401,"indent":0,"parameters":["wasn't that just a bit too hasty?"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Now that we're alone like this, I just can't find the words to say to her."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[16-nb]Hey, so that talk... w-what is it?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["The one who created this inescapable situation was none other than me myself."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["--All that's left, is to say what I have to say."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Or so it should be, but my bad habit filters out"]},{"code":401,"indent":0,"parameters":["my true feelings from the statement."]},{"code":357,"indent":0,"parameters":["MPP_ChoiceEX","choicePos","選択肢位置設定",{"x":"410","y":"300","row":"0"}]},{"code":657,"indent":0,"parameters":["x = 410"]},{"code":657,"indent":0,"parameters":["y = 300"]},{"code":657,"indent":0,"parameters":["行数 = 0"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Even though all I need to say is [I love you, please go out with me]...."]},{"code":102,"indent":0,"parameters":[["How about... we become a temp couple?"],-1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"How about... we become a temp couple?"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[128]\\SE[2]Wah.... Really? I-I've always wanted that too..."]},{"code":242,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[123]\\SE[8]Wait. Eh? \"Temp\"?"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["She's tilting her head so much I wonder if it's gonna snap off."]},{"code":241,"indent":0,"parameters":[{"name":"BGM3_12","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["...I've done it now."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It really is a bad habit. Whenever it's something important relating to her,"]},{"code":401,"indent":0,"parameters":["I always end up running away from it."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Now that it's come to this, I can only press on."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["\"The others are really starting to get on my nerves, you know?\" or,"]},{"code":401,"indent":0,"parameters":["\"You'll stop getting all those confessions too\" or..."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I rattle off one 'benefit' after another of this 'arrangement',"]},{"code":401,"indent":0,"parameters":["really, whatever just comes to mind."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[15-nb]Hmm hmm... I see."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Wondering why I just can't be honest, I start feeling sick of my own"]},{"code":401,"indent":0,"parameters":["lameness, but people can't change that easily anyway."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Maybe I have some pride still left deep within my heart somewhere, as her childhood friend."]},{"code":401,"indent":0,"parameters":["About how \"she won't choose anyone other than me anyway\"."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Seems like that dream from earlier taught me nothing at all in the end."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Just as I was about done explaining the outline of the [Temp couple plan] that I just came up "]},{"code":401,"indent":0,"parameters":["with, she'd straightened her head out, and let out a very deep sigh."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[129]\\SE[12]Haah.... Well, I guess as far as you go, this is still pretty brave, \\n[1]."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[123]\\se[17-nb]Say, mind if I ask you something instead?"]},{"code":401,"indent":0,"parameters":["Are you okay with this, \\n[1]? ....With me as your temp girlfriend."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[15-nb]I mean, if you're using that logic for it then... does it"]},{"code":401,"indent":0,"parameters":["have to be me? I mean, I don't like saying it myself but..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[12]Wouldn't you have a lot more peaceful life if you went with someone else instead?"]},{"code":401,"indent":0,"parameters":["I uhm... I get confessed to a lot, you know."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Is she thinking that I'd be fine with any girl as long as she'd be my girlfriend...?"]},{"code":401,"indent":0,"parameters":["That really would be too much of a misunderstanding, I have to tell her properly this time."]},{"code":357,"indent":0,"parameters":["MPP_ChoiceEX","choicePos","選択肢位置設定",{"x":"480","y":"300","row":"0"}]},{"code":657,"indent":0,"parameters":["x = 480"]},{"code":657,"indent":0,"parameters":["y = 300"]},{"code":657,"indent":0,"parameters":["行数 = 0"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["The only one that I can ask this from is..."]},{"code":102,"indent":0,"parameters":[["Only you, Shino, nobody else."],-1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"Only you, Shino, nobody else."]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\sa[128]\\SM[tremble]\\SE[8]....!? H-How can you say stuff"]},{"code":401,"indent":0,"parameters":["like that so easily and yet you..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[16]Haah... you're so unfair... I give up."]},{"code":401,"indent":0,"parameters":["Sure, but I have some conditions too, okay?"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[10]Let's put a hard limit on this 'relationship', as the last day of the su