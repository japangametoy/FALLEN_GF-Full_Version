't let you have him~!"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Apparently the Kurumizawas' father is always away due to business,"]},{"code":401,"indent":0,"parameters":["but I could tell from the way they talked about him that they all loved him very much."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Though I probably lost something very precious,"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Don't worry, mom. --- I'll do my best."]},{"code":242,"indent":0,"parameters":[3]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","focus","[演出]focus/フォーカス",{"name":"all","wait":"def","onlyFlag":"true"}]},{"code":657,"indent":0,"parameters":["対象キャラ名 = all"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["他キャラをアンフォーカス = true"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["--- As long as these three are here, as long as this place is here for me."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I'll definitely be fine."]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[100]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","end","スキット終了",{"noAnimation":"false"}]},{"code":657,"indent":0,"parameters":["瞬時に非表示 = false"]},{"code":235,"indent":0,"parameters":[1]},{"code":201,"indent":0,"parameters":[1,26,27,28,0,0]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":40,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":40,"indent":null}]},{"code":223,"indent":0,"parameters":[[0,0,0,0],20,true]},{"code":117,"indent":0,"parameters":[89]},{"code":117,"indent":0,"parameters":[97]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"para