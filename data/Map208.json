{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":117,"indent":0,"parameters":[90]},{"code":211,"indent":0,"parameters":[0]},{"code":241,"indent":0,"parameters":[{"name":"SBGMv2_06","volume":90,"pitch":100,"pan":0}]},{"code":223,"indent":0,"parameters":[[-255,-255,-255,0],1,false]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["-- It wasn't that long after I'd met Shino that my mother passed away."]},{"code":401,"indent":0,"parameters":["Maybe a few months at most."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Suddenly, my life was a motherless one."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["At the time, I didn't really understand the concept of death,"]},{"code":401,"indent":0,"parameters":["so I went up and asked my father."]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","pose","[表情/ポーズ]pose/ポーズ変更",{"name":"Shino","wait":"def","pose":"youjyo","expression":"","style":"def","duration":"def","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Shino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["ポーズ名 = youjyo"]},{"code":657,"indent":0,"parameters":["表情名 = "]},{"code":657,"indent":0,"parameters":["アニメーションタイプ = def"]},{"code":657,"indent":0,"parameters":["所要時間 = def"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","pose","[表情/ポーズ]pose/ポーズ変更",{"name":"Rino","wait":"def","pose":"gaku","expression":"","style":"def","duration":"def","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Rino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["ポーズ名 = gaku"]},{"code":657,"indent":0,"parameters":["表情名 = "]},{"code":657,"indent":0,"parameters":["アニメーションタイプ = def"]},{"code":657,"indent":0,"parameters":["所要時間 = def"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["\"Why hasn't mom come home yet?\""]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Father"]},{"code":401,"indent":0,"parameters":["....It's my, it's my fault."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["-- Even now, those words my father said back then still exist as a rift between us."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Of course, I know now that my father wasn't the direct cause."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It was likely just a lie he happened to tell the young me, on the spur of the moment."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["However, it's the fact that even now he adamantly refuses"]},{"code":401,"indent":0,"parameters":["to tell me exactly what happened back then, that I can't forgive."]},{"code":235,"indent":0,"parameters":[100]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","moveOut","[退出]moveOut/ムーブアウト",{"name":"Father","wait":"def","speed":"def","direction":"auto","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Father"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["スライドスピード = def"]},{"code":657,"indent":0,"parameters":["スライド方向。 = auto"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":242,"indent":0,"pa