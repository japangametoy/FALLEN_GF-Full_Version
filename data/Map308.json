{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":211,"indent":0,"parameters":[0]},{"code":241,"indent":0,"parameters":[{"name":"M03_Mattari_guitar","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"bg019b",0,0,0,0,100,100,255,0]},{"code":357,"indent":0,"parameters":["NRP_PicturePriority","SetZ","Ｚ座標を設定",{"PictureId":"1","Z":"0.90"}]},{"code":657,"indent":0,"parameters":["ピクチャ番号 = 1"]},{"code":657,"indent":0,"parameters":["Ｚ座標 = 0.90"]},{"code":223,"indent":0,"parameters":[[0,0,0,0],30,true]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I decided to walk home together with Shino."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I did feel a bit uneasy over how she refused to do anything but follow me at a distance \nthough."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Wait, I did a lot of physical work today, do I... reek of sweat or something..."]},{"code":122,"indent":0,"parameters":[73,73,1,0,1]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","pose","[表情/ポーズ]pose/ポーズ変更",{"name":"Shino","wait":"def","pose":"sihuku","expression":"","style":"def","duration":"def","easeType":"def"}]},{"code":657,"indent":0,"parameters":["キャラ名 = Shino"]},{"code":657,"indent":0,"parameters":["ウェイト = def"]},{"code":657,"indent":0,"parameters":["ポーズ名 = sihuku"]},{"code":657,"indent":0,"parameters":["表情名 = "]},{"code":657,"indent":0,"parameters":["アニメーションタイプ = def"]},{"code":657,"indent":0,"parameters":["所要時間 = def"]},{"code":657,"indent":0,"parameters":["イージング = def"]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[54-nb]H-Hey, \\n[1]. Why'd you suddenly start working...?"]},{"code":401,"indent":0,"parameters":["And you didn't tell me either...."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Now that I've come this far, I can't exactly lie to her."]},{"code":401,"indent":0,"parameters":["Especially now that I'm just considering looking for something to buy."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["[To earn money to buy a gift for you, of course.]"]},{"code":401,"indent":0,"parameters":["I honestly told her."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\se[55-nb]---------------------!!"]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[54-nb]I-I see.... E-Eheheh... I'm so happy..."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I actually wanted to tell her about it with the present in hand but,"]},{"code":401,"indent":0,"parameters":["when I said it, I saw her twitch."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Come to think of it, what was she doing in a place like that?"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":117,"indent":0,"parameters":[96]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[18]Eh? M-Me? Just to read some manga..."]},{"code":401,"indent":0,"parameters":["I-I'm sure you know, since you work there..."]},{"code":101,"indent":0,"parameters":["",0,2,2,"Shino"]},{"code":401,"indent":0,"parameters":["\\SE[18]The selection there is great so, I've been a regular for a long time."]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["[Weird how we never passed by each other before, huh?]"]},{"code":401,"indent":0,"parameters":["...she awkwardly laughed and said."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":[".............."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["I was considering telling her about what I saw in the couples' lounge"]},{"code":401,"indent":0,"parameters":["but seems like it'd be best to hold off on that."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["It's not something to talk with a girl about anyway. I'll discuss it with Jun later."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["And so I went back home, with Shino clammed up behind me."]},{"code":121,"indent":0,"parameters":[448,448,0]},{"code":357,"indent":0,"parameters":["TRP_SkitMZ","end","スキット終了",{"noAnimation":"false"}]},{"code":657,"indent":0,"parameters":["瞬時に非表示 = false"]},{"code":357,"indent":0,"parameters":["MPP_ChoiceEX","choicePos","選択肢位置設定",{"x":"580","y":"300","row":"0"}]},{"code":657,"indent":0,"parameters":["x = 580"]},{"code":657,"indent":0,"parameters":["y = 300"]},{"code":657,"indent":0,"parameters":["行数 = 0"]},{"code":117,"indent":0,"parameters":[98]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Would you like to see the story from Shino's viewpoint?"]},{"code":102,"indent":0,"parameters":[["Yes","No"],-1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"Yes"]},{"code":235,"indent":1,"parameters":[100]},{"code":221,"indent":1,"par